# ── Polymarket US API credentials ───────────────────────────────
# Authenticated via ED25519 (see core/polyclient.py). Get these from your
# Polymarket US account API settings. Keep the real values in .env (gitignored).
POLYMARKET_API_KEY=your-api-key-id-here
POLYMARKET_SECRET=your-base64-secret-here

# ── Bot mode & risk params (poly_runner.py) ─────────────────────
BOT_MODE=shadow          # shadow = no orders reach the exchange; flip to "live"
                         # ONLY after the live reward economics validate
POLY_BUDGET=200          # capital budget (USD)
POLY_SIZE=100            # per-side order size (contracts), scaled by MAX_MARKETS
POLY_MAX_INVENTORY=300   # per-market inventory cap (breaker trips above)
POLY_DAILY_LOSS=15       # best-effort daily unrealized-loss breaker (USD)
POLY_EXPOSURE_CAP=300    # total filled-exposure breaker (USD); default 1.5×BUDGET
POLY_MAX_MARKETS=5       # max reward markets quoted at once (bounds budget)
POLY_POLL_SECS=20        # cycle interval

# ── Pilot selection (deep-dive: competed + catalyst-free first) ──
POLY_DENY_PREFIXES=aec-cod-   # never quote these slug prefixes (esports COD)
POLY_MIN_HOURS_TO_END=72      # skip markets settling sooner than this
POLY_MIN_MID=0.10
POLY_MAX_MID=0.90
POLY_REQUIRE_COMPETED=1       # skip near-zero competition books (set 0 to allow)
POLY_EARNINGS_SECS=3600       # poll /v1/incentives/earnings cadence

# ── Render MCP (.mcp.json reads this) ───────────────────────────
RENDER_API_KEY=your-render-api-key-here
