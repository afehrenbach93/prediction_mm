# ── Polymarket US API credentials ───────────────────────────────
# Authenticated via ED25519 (see core/polyclient.py). Get these from your
# Polymarket US account API settings. Keep the real values in .env (gitignored).
POLYMARKET_API_KEY=your-api-key-id-here
POLYMARKET_SECRET=your-base64-secret-here

# ── Bot mode & risk params (poly_runner.py) ─────────────────────
BOT_MODE=shadow          # shadow = no orders reach the exchange; flip to "live"
                         # ONLY after the live reward economics validate
POLY_BUDGET=200          # capital budget (USD)
POLY_SIZE=100            # per-side order size (contracts), scaled by MAX_MARKETS
POLY_MAX_INVENTORY=300   # per-market inventory cap (breaker trips above)
POLY_DAILY_LOSS=15       # best-effort daily unrealized-loss breaker (USD)
POLY_EXPOSURE_CAP=300    # total filled-exposure breaker (USD); default 1.5×BUDGET
POLY_MAX_MARKETS=5       # max reward markets quoted at once (bounds budget)
POLY_POLL_SECS=20        # cycle interval
POLY_VOL_CAP=0           # Stage 2: hard-exclude reward markets with rolling vol >
                         # this ($ mid-move/min) as too adverse-selection-prone.
                         # 0 = no hard exclusion (still ranks by reward-rate/vol).

# ── Reward-yield diagnostic (Stage 1, read-only; poly_runner track mode) ─
REWARD_YIELD=            # set to "1" to log+heartbeat the reward-yield ranking
REWARD_YIELD_TOPN=12     # top markets (by reward/hr) tracked for rolling volatility
                         # vol accrues from a per-cycle sampler; re-ranked every 10min

# ── Whale scout (read-only copy-trading research; offshore .com observe-only) ─
WHALE_SCOUT=             # set to "1" to scout top wallets by OFFICIAL profit
WHALE_SCOUT_N=10         # how many profit-ranked whales to track
WHALE_SCOUT_MIN_PROFIT=10000  # min lb-api/profit ($); drops losers/noise
WHALE_SCOUT_WINDOW=30d   # all | 30d | 7d
WHALE_SCOUT_TRADE_LIMIT=40    # recent TRADE rows pulled per focused whale/cycle

# ── Flow scout (read-only informed-flow / endgame-size research) ─
FLOW_SCOUT=                   # set to "1" to flag large tape prints near market end
FLOW_SCOUT_MULT=5             # size must be ≥ mult × per-slug baseline median
FLOW_SCOUT_MIN_SIZE=100       # absolute contract floor
FLOW_SCOUT_ENDGAME_MIN=180    # only flag if ≤ this many minutes to end (0 = any time)
FLOW_SCOUT_TRADE_LIMIT=120    # recent global trades pulled each cycle

# ── Render MCP (.mcp.json reads this) ───────────────────────────
RENDER_API_KEY=your-render-api-key-here
