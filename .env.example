# ── ACTIVE: Global CLOB (deep-dive plan) ────────────────────────
# Eligibility (ops): confirm US/FL access + Polymarket ToS for global
# polymarket.com (historically US-restricted) BEFORE setting live.
# This flag asserts the operator did that check; it does not perform it.
ELIGIBILITY_CONFIRMED=false      # REQUIRED true (with CLOB_MODE=live) for live orders

# Wallet hygiene: use a DEDICATED Polygon wallet funded only with pilot capital.
# Never export the main Magic wallet key into CLOB_PRIVATE_KEY.
# Set CLOB_FUNDER + CLOB_SIGNATURE_TYPE so leaked L2 creds cannot spend beyond
# the pilot wallet / proxy.
CLOB_MODE=shadow                 # shadow | live | off  (default shadow)
CLOB_HOST=https://clob.polymarket.com
CLOB_CHAIN_ID=137
CLOB_PRIVATE_KEY=                # L1 pilot wallet key only (never commit)
CLOB_API_KEY=                    # L2 from derive script
CLOB_SECRET=
CLOB_PASS_PHRASE=
CLOB_FUNDER=                     # deposit wallet address for sig type 3
CLOB_SIGNATURE_TYPE=0            # 0=EOA, 1=proxy/Magic, 3=deposit wallet POLY_1271
# Live deposit-wallet (sig type 3) uses polymarket-client SecureClient by default.
# CLOB_USE_SECURE_CLIENT=0       # force legacy py-clob-client-v2
# Builder keys (gasless / SecureClient create) — NOT the same as CLOB L2 keys:
# POLYMARKET_BUILDER_API_KEY=
# POLYMARKET_BUILDER_SECRET=
# POLYMARKET_BUILDER_PASSPHRASE=
# Derive L2 keys:
#   CLOB_PRIVATE_KEY=0x... PYTHONPATH=. python3 scripts/clob_derive_keys.py

# Micro-pilot defaults (§7.5): $50–100/mkt, 2–3 competed markets
CLOB_BUDGET_PER_MARKET=75
CLOB_MAX_MARKETS=3
CLOB_MAX_INVENTORY=200
CLOB_SPREAD_FRACTION=0.5         # quote at half max_spread
CLOB_EXPOSURE_CAP=337.5          # ~1.5 × budget × markets
CLOB_POLL_SECS=30
CLOB_MIN_HOURS_TO_END=168        # 7d — boring / no imminent catalyst
CLOB_PILOT_CSV=data/clob_scans/pilot_universe.csv
CLOB_EARNINGS_SECS=3600
CLOB_WS=1                        # market websocket mids (REST fallback on drop)
CLOB_MID_MOVE_TICKS=1
CLOB_MAX_REFRESH_SECS=2
CLOB_CSV_DUMP=1                  # optional local dump; SoT is Supabase

# Kill switch (polled each loop): env OR Supabase clob_control.kill
CLOB_KILL=false                  # true → cancel all, stand aside, keep process up

# Supabase ledger (required for persistent fills/rewards/pnl + remote kill)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=       # preferred for inserts
SUPABASE_ANON_KEY=               # fallback if service role unavailable
# Apply schema: sql/0002_clob_ledger.sql

# Scale gate (§7.6): reads Supabase clob_daily_pnl
#   PYTHONPATH=. python3 scripts/clob_scale_gate.py

# ── PARKED: Polymarket US (no proven edge) ──────────────────────
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
BOT_MODE=shadow
POLY_BUDGET=200
POLY_SIZE=100
POLY_MAX_INVENTORY=300
POLY_DAILY_LOSS=15
POLY_EXPOSURE_CAP=300
POLY_MAX_MARKETS=5
POLY_POLL_SECS=20

# ── Render MCP ──────────────────────────────────────────────────
RENDER_API_KEY=
